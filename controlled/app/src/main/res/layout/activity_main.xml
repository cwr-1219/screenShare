<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F7F7"
    android:padding="24dp"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:text="父母端远程协助"
        android:textColor="#1A202C"
        android:textSize="22sp"
        android:letterSpacing="0.05"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 1. 服务端配置卡片 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_server"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="16dp"
        app:cardElevation="1dp"
        app:cardMaxElevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/tv_title">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="配置连接"
                android:textColor="#2D3748"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- 极简嵌入式圆角背景输入框，无需多余的 drawable 文件 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    app:cardBackgroundColor="#F3F4F6"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp">

                    <EditText
                        android:id="@+id/et_server_ip"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:hint="服务器 IP"
                        android:inputType="phone"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:text="192.168.31.219"
                        android:textColor="#1A202C"
                        android:textSize="15sp" />
                </androidx.cardview.widget.CardView>

                <Button
                    android:id="@+id/btn_connect"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_marginStart="12dp"
                    android:text="连接"
                    android:textColor="#1A202C"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:strokeColor="#E2E8F0"
                    app:strokeWidth="1dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="● 未连接"
                android:textColor="#E53E3E"
                android:textSize="13sp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 2. 连接配对码卡片 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_pairing"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="16dp"
        app:cardElevation="1dp"
        app:cardMaxElevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/card_server">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="连接配对码"
                android:textColor="#718096"
                android:textSize="13sp"
                android:letterSpacing="0.02" />

            <TextView
                android:id="@+id/tv_pairing_code"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="------"
                android:textColor="#1A202C"
                android:textSize="44sp"
                android:textStyle="bold"
                android:letterSpacing="0.08" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="请将上面 6 位数字告知您的子女"
                android:textColor="#A0AEC0"
                android:textSize="12sp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 3. 权限引导卡片 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_permissions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="16dp"
        app:cardElevation="1dp"
        app:cardMaxElevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/card_pairing">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="服务授权"
                android:textColor="#2D3748"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- 无障碍权限 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="无障碍手势模拟"
                    android:textColor="#1A202C"
                    android:textSize="14sp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/tv_permission_accessibility"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    android:text="未开启"
                    android:textColor="#E53E3E"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btn_grant_accessibility"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="去开启"
                    android:textColor="#1A202C"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:strokeColor="#E2E8F0"
                    app:strokeWidth="1dp" />
            </LinearLayout>

            <!-- 投屏权限 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="屏幕共享投屏"
                    android:textColor="#1A202C"
                    android:textSize="14sp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/tv_permission_projection"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    android:text="未运行"
                    android:textColor="#E53E3E"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btn_start_projection"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="启动投屏"
                    android:textColor="#1A202C"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:strokeColor="#E2E8F0"
                    app:strokeWidth="1dp" />
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
