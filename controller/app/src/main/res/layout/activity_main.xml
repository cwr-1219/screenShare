<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EAEFF5"
    tools:context=".MainActivity">

    <!-- 顶部连接控制面板 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_control"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="10dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="3dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/et_server_ip"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.2"
                    android:hint="服务器 IP"
                    android:inputType="phone"
                    android:text="192.168.31.219"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/et_pair_code"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:hint="6位配对码"
                    android:inputType="number"
                    android:maxLength="6"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/btn_pair"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:backgroundTint="#3182CE"
                    android:text="配对"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="未连接"
                android:textColor="#718096"
                android:textSize="12sp"
                android:textStyle="bold" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 远程画面渲染区（自定义 View 拦截手势） -->
    <com.helper.controller.InteractiveImageView
        android:id="@+id/iv_screen"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="10dp"
        android:background="#2D3748"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/card_control" />

    <!-- 画面占位文案 -->
    <TextView
        android:id="@+id/tv_placeholder"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="等待建立连接，在此处操作妈妈手机"
        android:textColor="#A0AEC0"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="@id/iv_screen"
        app:layout_constraintEnd_toEndOf="@id/iv_screen"
        app:layout_constraintStart_toStartOf="@id/iv_screen"
        app:layout_constraintTop_toTopOf="@id/iv_screen" />

</androidx.constraintlayout.widget.ConstraintLayout>
